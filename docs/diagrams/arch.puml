@startuml
skinparam linetype ortho
skinparam PackageStyle rectangle
skinparam roundcorner 10
skinparam ParticipantPadding 10
skinparam BoxPadding 10

title Modular Database Storage & Concurrency Architecture (Fixed Syntax)

' ========================================================
' 1. UNDO & ROLLBACK LAYER (NEW - isolation from WAL/MVCC)
' ========================================================
package "Undo & Rollback Management" as UndoLayer #FFFACD {
    interface "Operation" as IOperation <<interface>> #FFD700 {
        + Undo(bufferMgr: IBufferManager) : error
        + GetID() : uint64
    }

    class "PageWriteOp" as PageOp #FFFACD {
        - opID: uint64
        - pageID: ResourcePageID
        - offset: uint16
        - beforeData: []byte
        + Undo(bufferMgr)
    }

    class "CompositeOp" as CompOp #FFFACD {
        - opID: uint64
        - operations: []Operation
        + Undo(bufferMgr)
    }

    class "UndoLog" as UndoLog #FFFACD {
        - txnID: uint64
        - operations: []Operation
        + RecordOp(op: Operation)
        + Rollback(bufferMgr) : error
        + RollbackToPoint(point: int) : error
        + SavePoint() : int
    }

    class "RollbackManager" as RollbackMgr #FFFACD {
        - bufferMgr: IBufferManager
        - nextOpID: uint64
        + RecordPageWrite(...) : opID
        + RollbackTransaction(txn) : error
        + RollbackToSavePoint(txn, point) : error
    }

    IOperation <|-- PageOp
    IOperation <|-- CompOp
    UndoLog *-- IOperation
    RollbackMgr *-- UndoLog
}

' ========================================================
' 1b. WRITE-AHEAD COORDINATION LAYER  (NEW - bridges logging + undo)
' ========================================================
package "Write-Ahead Coordination" as WriteAheadLayer #FFE4CD {
    interface "WriteHandler" as IWriteHandler <<interface>> #FF8C00 {
        + HandleWrite(txn, op: WriteOp) : error
    }

    class "DefaultWriteHandler" as DefaultWrite #FFE4CD {
        - rollbackMgr: RollbackManager
        - logManager: ILogManager
        - tableSchema: TableSchema
        - indexMgr: IndexManager
        + HandleWrite(txn, op: WriteOp) : error
        + SetIndexContext(schema, indexMgr) : error
    }

    class "WriteOp" as WriteOpData #FFE4CD {
        - key: []byte
        - value: []byte
        - pageID: ResourcePageID
        - offset: uint16
    }
}

' ========================================================
' 2. TRANSACTION & LOGICAL CONCURRENCY LAYER
' ========================================================
package "Transaction Management" as LogicalLayer #E0FFFF {
    interface "IsolationManager" as IIsolation <<interface>> #ADD8E6 {
        + BeginTransaction(IsoLevel)
        + Read(TxID, Key) : Value
        + Write(TxID, Key, Value)
        + Commit(TxID)
        + Abort(TxID)
    }

    class Transaction {
        - txnID: uint64
        - state: TxnState
        - undoLog: *UndoLog
        - locks: [][]byte
        - tableName: string
        - tableSchema: *TableSchema
        - cleanupCallbacks: []func()
        + SetTableContext(name, schema)
        + GetTableContext() : (name, schema)
        + RecordOperation(op: Operation) : error
        + RegisterCleanupCallback(func)
        + ExecuteCleanupCallbacks() : error
        + Rollback(bufferMgr) : error
        + SavePoint() : int
    }

    class TransactionManager {
        - isoHandler: IsolationManager
        - writeHandler: WriteHandler
        - bufferPool: IBufferManager
        - indexMgr: IndexManager
        - schemaManager: SchemaManager
        + BeginTransaction(isolationLevel, tableName)
        + Commit(txnID)
        + Abort(txnID)
    }

    class "TwoPhaseLockManager (2PL)" as 2PL #FFE4E1 {
        - LockTable
        - DeadlockDetector: Wait-For-Graph
        - writeHandler: WriteHandler
        + AcquireIndexLocks(txn, indexName, value)
        + ReleaseIndexLocks(txn)
    }

    class "MVCCManager" as MVCC #FFE4E1 {
        - VersionStore
        - TimestampOracle
        - writeHandler: WriteHandler
        + CaptureIndexSnapshot(tableSchema) : Snapshot
        + ValidateIndexSnapshot(snapshot) : error
        + ProvideSnapshot()
    }

    class "OCCManager" as OCC #FFE4E1 {
        - ReadSet
        - WriteSet
        - writeHandler: WriteHandler
        + CaptureIndexSnapshot(tableSchema) : Snapshot
        + DetectIndexConflicts(newSnapshot) : error
        + Validate()
    }
    
    Transaction *-- UndoLog
}

' ========================================================
' 2a. SCHEMA MANAGEMENT LAYER (NEW - schema definitions)
' ========================================================
package "Schema Management" as SchemaLayer #E0E0E0 {
    note top
        Defines table structure independent of data
        No transaction awareness, no locking
    end note

    class DataType <<enumeration>> #F0F0F0 {
        Int64, String, Bytes
        Float64, Bool, Nullable
    }

    class Column #E0E0E0 {
        - name: string
        - dataType: DataType
        - nullable: bool
    }

    class IndexType <<enumeration>> #F0F0F0 {
        Primary, Secondary, Unique
    }

    class Index #E0E0E0 {
        - name: string
        - type: IndexType
        - columns: []string
        - isUnique: bool
        - isSparse: bool
    }

    class TableSchema #E0E0E0 {
        - name: string
        - primaryKey: string
        - columns: Map<name, Column>
        - indexes: Map<name, Index>
        - createdAt: int64
        - modifiedAt: int64
        + AddColumn(name, type, nullable)
        + AddIndex(name, type, columns, isUnique)
        + GetColumn(name) : Column
        + GetIndex(name) : Index
        + Validate() : error
    }

    class SchemaManager #E0E0E0 {
        - tables: Map<tableName, TableSchema>
        + CreateTable(schema) : error
        + DropTable(name) : error
        + GetTableSchema(name) : TableSchema
        + ListTables() : []string
    }

    TableSchema *-- Column
    TableSchema *-- Index
    SchemaManager *-- TableSchema
    Column *-- DataType
    Index *-- IndexType
}

' ========================================================
' 2b. LOGICAL INDEXING LAYER (with schema integration)
' ========================================================
package "Logical Index Management" as IndexLayer #E0FFFF {
    interface "Index" as IIndex <<interface>> #ADD8E6 {
        + Insert(Key, Value)
        + Get(Key) : Value
        + Scan(Lower, Upper) : Iterator
        + Delete(Key) : error
    }

    class IndexManager #FFE4E1 {
        - tableSchema: TableSchema
        - indexes: Map<IndexName, StorageEngine>
        - writeHandler: WriteHandler
        + AddToIndex(indexName, value, primaryKey)
        + RemoveFromIndex(indexName, value, primaryKey)
        + GetPrimaryKeysForValue(indexName, value)
        + RangeQueryIndex(indexName, start, end)
        + GetIndexStats(indexName) : IndexStats
        ___
        Automatic maintenance on:
        INSERT (add entries), DELETE (remove entries)
        UPDATE (remove old + add new entries)
    }

    class "PrimaryIndex (Clustered)" as Primary #FFE4E1 {
        - backend: StorageEngine
        - schema: TableSchema
    }

    class "SecondaryIndex (Unclustered)" as Secondary #FFE4E1 {
        - backend: StorageEngine
        - indexDef: Index
        + MaintainOnWrite(txn, oldRow, newRow)
    }

    IndexManager o-- SchemaManager : references
    IIndex <|-- PrimaryIndex
    IIndex <|-- SecondaryIndex
}

' ========================================================
' 3. PHYSICAL ACCESS METHODS (STORAGE ENGINES)
' ========================================================
package "Physical Access Methods (Pure Storage)" as StorageLayer #FFFEF0 {
    note top
        ✗ NO WAL DEPENDENCIES
        ✓ PURE DATA STRUCTURE OPERATIONS
        ✓ Thread-safe via page latching
        ✗ NO TRANSACTION AWARENESS
    end note

    interface "StorageEngine (KV)" as IStorage <<interface>> #ADD8E6 {
        + Put(key: []byte, value: []byte) : error
        + Get(key: []byte) : ([]byte, error)
        + Delete(key: []byte) : error
        + Scan(lower, upper) : Iterator
    }

    abstract class "BPlusTreeBackend" as BTree {
        - bufferPool: IBufferManager
        - latchMechanism: ILatchStrategy
        + Split_Node()
        + Merge_Node()
        ___
        Note: Calls only methods above
        NO calls to logManager!
    }

    class "DiskBased_BPlusTree" as DiskBTree #FFF
    class "LSMTreeBackend" as LSM #FFF {
        - sstableMgr: SSTableManager
        - compaction: Compactor
    }
}

' ========================================================
' 4. PHYSICAL CONCURRENCY (LATCHING STRATEGIES)
' ========================================================
package "Physical Structure Concurrency" as LatchLayer #FFDAB9 {
    interface "ILatchStrategy" as ILatch <<interface>> #ADD8E6 {
        + AcquirePageLatch(PageID, Mode)
    }

    class "LatchCrabbing (Pessimistic)" as LatchCrabbing #FFF
    class "B-link_Logic (LinkPointers)" as BLink #FFF
}

' ========================================================
' 5. RESOURCE MANAGEMENT LAYER
' ========================================================
package "Resource & I/O Management" as ResourceLayer #D3D3D3 {
    interface "IBufferManager" as IBuffer <<interface>> #ADD8E6 {
        + PinPage(PageID)
        + UnpinPage(PageID, isDirty)
    }
    class BufferPoolManager #FFF

    interface "ILogManager (WAL)" as IWAL <<interface>> #ADD8E6 {
        + AppendLogRecord(LogRecord)
        + FlushToDisk()
    }
    class WALImplementation #FFF
}

' ========================================================
' RELATIONSHIPS & DEPENDENCIES
' ========================================================

' --- WRITE-AHEAD COORDINATION ---
TransactionManager *-- IWriteHandler : provides
IIsolation ..> IWriteHandler : uses for Write ops
2PL ..> IWriteHandler : delegates Write
MVCC ..> IWriteHandler : delegates Write
OCC ..> IWriteHandler : delegates Write (validation phase)

DefaultWrite *-- RollbackMgr : records ops to UndoLog
DefaultWrite o-- IWAL : optional WAL logging
DefaultWrite o-- IStorage : calls storage ops

' --- UNDO/ROLLBACK LAYER INTEGRATION ---
TransactionManager *-- RollbackMgr : provides
RollbackMgr o-- IBuffer : uses for undo
IIsolation ..> RollbackMgr : uses for rollback on Abort

' --- TRANSACTION MANAGEMENT ---
TransactionManager *-- IIsolation
TransactionManager *-- IndexManager
TransactionManager *-- Transaction
TransactionManager *-- SchemaManager
Transaction o-- TableSchema : references schema
IndexManager *-- IIndex
IndexManager *-- TableSchema : uses for index definitions

' --- STORAGE ENGINE ISOLATION ---
IStorage ..> IBuffer : accesses pages ONLY
BTree --|> IStorage
LSM --|> IStorage
BTree *-- IBuffer
BTree *-- ILatch

' --- INHERITANCE HIERARCHIES ---
IIsolation <|-- 2PL
IIsolation <|-- MVCC
IIsolation <|-- OCC

IIndex <|-- Primary
IIndex <|-- Secondary

IWriteHandler <|-- DefaultWrite

Primary *-- IStorage
Secondary *-- IStorage

BTree <|-- DiskBTree

ILatch <|-- LatchCrabbing
ILatch <|-- BLink

IBuffer <|-- BufferPoolManager
IWAL <|-- WALImplementation

' --- LAYOUT & LAYERING ---
UndoLayer -[hidden]down- WriteAheadLayer
WriteAheadLayer -[hidden]down- LogicalLayer
LogicalLayer -[hidden]down- SchemaLayer
SchemaLayer -[hidden]down- IndexLayer
IndexLayer -[hidden]down- StorageLayer
StorageLayer -[hidden]down- LatchLayer
LatchLayer -[hidden]down- ResourceLayer

' --- KEY DESIGN INSIGHT NOTES ---
note top of UndoLayer
    ✓ Independent: Zero coupling to WAL
    ✓ In-memory rollback without parsing
    ✓ Works with any isolation or logging strategy
end note

note right of SchemaLayer
    ✓ Defines table structure once at table creation
    ✓ Used by all layers: transactions, indexes, storage
    ✓ No transaction locks on schema (stable)
    ✓ Supports compound indexes and data types
end note

note right of 2PL
    ✓ Index-aware locking with format: __index:table:index:value
    ✓ Prevents dirty reads on secondary indexes
    ✓ Automatic cleanup on rollback
end note

note right of MVCC
    ✓ Index snapshot consistency via fingerprints
    ✓ Detects dropped/modified indexes pre-commit
    ✓ Prevents phantom reads on indexes
end note

note right of OCC
    ✓ Tracks index state changes per transaction
    ✓ Detects write-write index conflicts
    ✓ Conservative: any change causes abort
end note

note top of WriteAheadLayer
    ✓ Bridges transaction logic and storage
    ✓ Coordinates WAL (optional), operations, undo
    ✓ Captures before-images for crash recovery
    ✓ Records operations to UndoLog for abort
end note

note top of StorageLayer
    ✓ PURE: No WAL, transaction, or isolation awareness
    ✓ Thread-safe via page latching only
    ✓ Pluggable: Swap storage engines freely
    Note: Current BPlusTree calls logManager directly
          This MUST be removed!
end note

note right of DefaultWrite
    EXECUTION FLOW:
    1. Capture before-image from buffer
    2. (Optional) Log BEFORE to WAL
    3. Call storage.Put(key, value)
    4. Create PageWriteOp with before-image
    5. txn.RecordOperation(op) → UndoLog
    6. (Optional) Log AFTER to WAL
end note

note bottom of 2PL
    On Write: calls writeHandler.HandleWrite()
    On Abort: calls txn.Rollback(bufferMgr)
    ✓ No direct storage engine coupling
    ✓ No direct WAL coupling
end note

@enduml